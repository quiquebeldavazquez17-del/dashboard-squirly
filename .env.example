# Configuración de Clockify
CLOCKIFY_API_KEY=tu_api_key_aqui
CLOCKIFY_WORKSPACE_ID=tu_workspace_id_aqui
CLOCKIFY_API_BASE=https://api.clockify.me/api/v1
CLOCKIFY_USER_ID_ADRI=id_usuario_adri
CLOCKIFY_USER_ID_QUIQUE=id_usuario_quique

# Configuración de Google Sheets
GOOGLE_SHEETS_CSV_URL=tu_url_del_csv_aqui

# Configuración de Supabase
VITE_SUPABASE_URL=tu_url_de_supabase_aqui
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Configuración de Servidor
PORT=3000
NODE_ENV=development
